# Python ────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.Python
.eggs/
.pytest_cache/
.coverage
.coverage.*
# Local pytest helper scripts (used to invoke pytest inside docker python:3.12).
.run-pytest.sh
.run-pytest-with-pg.sh
htmlcov/
tests/_cov_html_python/
.tox/
.venv*/
venv/
env/
.python-version
*.egg

# Node / web ────────────────────────────────────────────────────────
node_modules/
web/dist/
web/coverage/
web/playwright-report/
web/test-results/
web/tsconfig.tsbuildinfo
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Go ─────────────────────────────────────────────────────────────────
*.test
*.out

# Editors / OS ──────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# CI artifact downloads (debugging) ─────────────────────────────────
e2e-logs*.zip
*.tar.gz

# Local artifacts (generated by engine-svc at runtime) ──────────────
# The directory itself is tracked via .gitkeep so the bind-mount target
# exists at clone time (otherwise Docker auto-creates it as root and
# breaks engine-svc/run-svc which run as non-root).
infra/artifacts/sim-*/
infra/artifacts/inf-*/
infra/artifacts/bat-*/
infra/artifacts/agt-*/
infra/artifacts/tco-*/
!infra/artifacts/.gitkeep

# Secrets — never commit ────────────────────────────────────────────
.env
.env.local
*.pem
*.key
secrets/

# Claude Code local config / session state (per-user, not for repo) ─
.claude/
